{
  "name": "@m3000/docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "dev": "next dev --turbopack",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "prebuild": "pnpm registry:copy",
    "registry:build": "pnpm registry:copy && shadcn build",
    "registry:copy": "tsx scripts/build-registry.ts",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@m3000/market": "workspace:*",
    "@tabler/icons-react": "3.40.0",
    "fumadocs-core": "16.6.17",
    "fumadocs-mdx": "14.2.10",
    "next": "16.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@types/mdx": "2.0.13",
    "@types/node": "22.14.1",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.3",
    "shadcn": "2.10.0",
    "tailwindcss": "4.2.1",
    "tsx": "4.21.0",
    "typescript": "5.9.2"
  }
}
