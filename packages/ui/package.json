{
  "name": "@m3000/market",
  "version": "0.0.1",
  "description": "React UI components for marketplace and auction experiences.",
  "keywords": ["react", "ui", "marketplace", "auction", "design-system"],
  "license": "MIT",
  "homepage": "https://market.m3000.io",
  "bugs": {
    "url": "https://github.com/maerzhase/market-ui/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/maerzhase/market-ui.git",
    "directory": "packages/ui"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsdown && postcss ./src/styles/index.css -o ./dist/styles.css --minify",
    "build:storybook": "storybook build",
    "build:watch": "tsdown --watch",
    "dev": "tsdown --watch",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "quality": "pnpm run lint && pnpm run format && pnpm run typecheck",
    "storybook": "storybook dev -p 6007",
    "typecheck": "tsc --noEmit"
  },
  "prepack": "pnpm run build",
  "dependencies": {
    "@base-ui/react": "1.3.0",
    "@base-ui/utils": "0.2.5",
    "@floating-ui/core": "1.7.5",
    "@floating-ui/dom": "1.7.6",
    "@floating-ui/react-dom": "2.1.8",
    "@floating-ui/utils": "0.2.11",
    "@tabler/icons-react": "3.40.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "motion": "12.35.2",
    "reselect": "5.1.1",
    "tabbable": "6.4.0",
    "tailwind-merge": "3.3.1"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@storybook/addon-a11y": "10.1.2",
    "@storybook/addon-docs": "10.1.2",
    "@storybook/addon-themes": "10.1.2",
    "@storybook/react": "10.1.2",
    "@storybook/react-vite": "10.1.2",
    "@tailwindcss/postcss": "4.1.11",
    "@tsconfig/vite-react": "7.0.2",
    "@types/node": "22.14.1",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.3",
    "postcss": "8.5.6",
    "postcss-cli": "11.0.1",
    "react": "19.2.4",
    "react-docgen-typescript": "2.4.0",
    "react-dom": "19.2.4",
    "storybook": "10.1.2",
    "tailwindcss": "4.2.1",
    "tsdown": "0.20.3",
    "typescript": "5.9.2",
    "typescript-eslint": "8.46.4",
    "vite-tsconfig-paths": "5.1.4"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "@types/react": {
      "optional": true
    },
    "@types/react-dom": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
