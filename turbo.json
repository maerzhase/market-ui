{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "lint": {
      "cache": true,
      "outputs": []
    },
    "format": {
      "cache": false
    },
    "format:check": {
      "cache": true,
      "outputs": []
    },
    "typecheck": {
      "cache": true,
      "outputs": []
    },
    "quality": {
      "cache": false,
      "dependsOn": ["lint", "format:check", "typecheck"]
    }
  }
}
